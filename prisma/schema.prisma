// Monitoring Dashboard - Prisma Schema
// Models: User, Domain, CheckLog

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  hashedPassword String
  name           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  domains        Domain[]
  serverGroups   ServerGroup[]
}

model ServerGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1") // Tailwind indigo-500
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domains     Domain[]
}

model Domain {
  id            String       @id @default(cuid())
  url           String
  customerName  String
  checkInterval Int          @default(5) // in minutes
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverGroupId String?
  serverGroup   ServerGroup? @relation(fields: [serverGroupId], references: [id], onDelete: SetNull)
  checkLogs     CheckLog[]

  @@index([isActive])
  @@index([serverGroupId])
}

model CheckLog {
  id         String   @id @default(cuid())
  domainId   String
  domain     Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  statusCode Int?
  latency    Int? // in milliseconds
  isUp       Boolean
  sslValid   Boolean?
  sslExpiry  DateTime?
  error      String?
  checkedAt  DateTime @default(now())

  @@index([domainId, checkedAt])
}
